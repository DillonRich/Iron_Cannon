{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ironcannon.dev/schemas/rule-fragment/v1",
  "type": "object",
  "required": ["id", "layer", "rulesetVersion", "content", "compliancePatterns"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 3,
      "pattern": "^(layer[1-4]/|auth-lifecycle/|billing-subscription/|stripe/)"
    },
    "layer": { "type": "integer", "enum": [1, 2, 3, 4] },
    "rulesetVersion": { "type": "string" },
    "flowId": { "type": ["string", "null"] },
    "moduleId": { "type": "string" },
    "adapterId": { "type": ["string", "null"] },
    "section": { "type": "string" },
    "content": { "type": "object" },
    "references": { "type": "array", "items": { "type": "string" } },
    "compliancePatterns": {
      "type": "object",
      "properties": {
        "required": { "type": "array" },
        "forbidden": { "type": "array" },
        "advisory": { "type": "array" }
      }
    },
    "metadata": { "type": "object" },
    "$schema": { "type": "string" }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ironcannon.dev/schemas/rules-manifest/v1",
  "type": "object",
  "required": ["rulesetVersion", "modules", "flows"],
  "additionalProperties": true,
  "properties": {
    "rulesetVersion": { "type": "string", "pattern": "^[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}$" },
    "publishedAt": { "type": "string", "format": "date-time" },
    "modules": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["fragmentIds", "flowId"],
        "properties": {
          "flowId": { "type": "string" },
          "fragmentIds": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "refCardIds": { "type": "array", "items": { "type": "string" } },
          "layer": { "type": "integer", "minimum": 1, "maximum": 4 }
        }
      }
    },
    "flows": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "wiremapFragmentId": { "type": "string" },
          "unhappyPathBundle": { "type": "string" }
        }
      }
    }
  }
}

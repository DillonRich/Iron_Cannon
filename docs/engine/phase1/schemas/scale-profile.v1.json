{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ironcannon.dev/schemas/scale-profile/v1",
  "type": "object",
  "required": ["tool", "sliceProfile", "maxOutboundTokens", "ragTopK"],
  "properties": {
    "tool": { "type": "string", "pattern": "^T[0-9]{2}$" },
    "sliceProfile": { "$ref": "https://ironcannon.dev/schemas/slice-profile/v1" },
    "maxRuleFragments": { "type": "integer", "minimum": 0 },
    "maxMapTokens": { "type": "integer", "minimum": 0 },
    "maxExplicitCards": { "type": "integer", "minimum": 0 },
    "ragTopK": { "type": "integer", "minimum": 0, "maximum": 12 },
    "maxOutboundTokens": { "type": "integer", "minimum": 1000 }
  },
  "additionalProperties": false
}

{
  "mcpServers": {
    "iron-cannon-local": {
      "comment": "Pro tier (T01–T08). Start: npm run ironcannon:serve. Setup: see README Quick start + /mcp-config.example.json at repo root.",
      "url": "http://127.0.0.1:8787/mcp",
      "headers": {
        "x-ironcannon-tier": "pro",
        "x-ironcannon-client": "cursor-dev",
        "x-ironcannon-api-key": "ic_dev_pro_testkey12345678"
      }
    },
    "iron-cannon-local-armor": {
      "comment": "Armor tier (T09–T11). Same server URL; tier via x-ironcannon-tier header.",
      "url": "http://127.0.0.1:8787/mcp",
      "headers": {
        "x-ironcannon-tier": "armor",
        "x-ironcannon-client": "cursor-armor"
      }
    },
    "iron-cannon-ironclad": {
      "comment": "IronClad tier (T12–T14). Dev keys are fake fixtures — see SECURITY.md.",
      "url": "http://127.0.0.1:8787/mcp",
      "headers": {
        "x-ironcannon-tier": "ironclad",
        "x-ironcannon-client": "cursor-ironclad",
        "x-ironcannon-api-key": "ic_dev_ironclad_legaltest12345678"
      }
    }
  }
}

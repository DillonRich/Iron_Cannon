{
  "version": "1.0.0",
  "minCoverageRate": 0.9,
  "codes": [
    { "code": "AUTH_MISSING", "trigger": { "apiKey": "" }, "expect": "AUTH_MISSING" },
    { "code": "AUTH_INVALID", "trigger": { "apiKey": "bad" }, "expect": "AUTH_INVALID" },
    { "code": "SUBSCRIPTION_INACTIVE", "trigger": { "subscription": "inactive" }, "expect": "SUBSCRIPTION_INACTIVE" },
    { "code": "TIER_INSUFFICIENT", "trigger": { "tier": "pro", "tool": "map_vulnerability_surfaces" }, "expect": "TIER_INSUFFICIENT" },
    { "code": "STACK_UNSUPPORTED", "trigger": { "deps": { "firebase": "10" } }, "expect": "STACK_UNSUPPORTED" },
    { "code": "SSOT_CONFLICT", "trigger": { "conflicts": ["hybrid-host"] }, "expect": "SSOT_CONFLICT" },
    { "code": "STACK_INCOMPLETE", "trigger": { "missingConfig": ["STRIPE_WEBHOOK_SECRET"] }, "expect": "STACK_INCOMPLETE" },
    { "code": "PRODUCT_TYPE_INVALID", "trigger": { "productType": "mobile_app" }, "expect": "PRODUCT_TYPE_INVALID" },
    { "code": "THROTTLE_LOOP_DETECTED", "trigger": { "sameModuleCalls": 6 }, "expect": "THROTTLE_LOOP_DETECTED" },
    { "code": "RATE_LIMIT_EXCEEDED", "trigger": { "requestsInWindow": 1001 }, "expect": "RATE_LIMIT_EXCEEDED" },
    { "code": "MODULE_NOT_FOUND", "trigger": { "moduleId": "M99-fake" }, "expect": "MODULE_NOT_FOUND" },
    { "code": "WIREMAP_NOT_FOUND", "trigger": { "wiremapId": null }, "expect": "WIREMAP_NOT_FOUND" },
    { "code": "WIREMAP_NOT_APPROVED", "trigger": { "wiremapApproved": false }, "expect": "WIREMAP_NOT_APPROVED" },
    { "code": "FLOW_NOT_FOUND", "trigger": { "flowId": "nonexistent-flow" }, "expect": "FLOW_NOT_FOUND" },
    { "code": "RULE_NOT_FOUND", "trigger": { "fragmentId": "missing/fragment" }, "expect": "RULE_NOT_FOUND" },
    { "code": "ENGINE_SCHEMA_FAILURE", "trigger": { "payload": { "bad": true } }, "expect": "ENGINE_SCHEMA_FAILURE" },
    { "code": "RULE_STORE_CORRUPT", "trigger": { "rulesetChecksum": "dead" }, "expect": "RULE_STORE_CORRUPT" },
    { "code": "REMOTE_UNAVAILABLE", "trigger": { "network": "down" }, "expect": "REMOTE_UNAVAILABLE" },
    { "code": "CLI_VERSION_UNSUPPORTED", "trigger": { "cliVersion": "0.0.1" }, "expect": "CLI_VERSION_UNSUPPORTED" },
    { "code": "DIFF_DRIFT_DETECTED", "trigger": { "hashDrift": true }, "expect": "DIFF_DRIFT_DETECTED" },
    { "code": "ROLLBACK_SNAPSHOT_MISSING", "trigger": { "rollbackModule": "M99" }, "expect": "ROLLBACK_SNAPSHOT_MISSING" },
    { "code": "COMPLIANCE_FAILED", "trigger": { "patternsMatched": 0 }, "expect": "COMPLIANCE_FAILED" },
    { "code": "PAYLOAD_TOO_LARGE", "trigger": { "bytes": 6000000 }, "expect": "PAYLOAD_TOO_LARGE" },
    { "code": "SCOPE_OUT_OF_BOUNDS", "trigger": { "scope": "desktop-only" }, "expect": "SCOPE_OUT_OF_BOUNDS" },
    { "code": "SCOPE_NOT_SUPPORTED", "trigger": { "scope": "recommend-stack" }, "expect": "SCOPE_NOT_SUPPORTED" },
    { "code": "FLOW_NOT_IN_CATALOG", "trigger": { "flowId": "custom-xyz" }, "expect": "FLOW_NOT_IN_CATALOG" },
    { "code": "MODULE_SEQUENCE_VIOLATION", "trigger": { "current": "M12", "priorVerified": ["M01"] }, "expect": "MODULE_SEQUENCE_VIOLATION" },
    { "code": "MODULE_DEPENDENCY_UNMET", "trigger": { "moduleId": "M12", "deps": ["M10"] }, "expect": "MODULE_DEPENDENCY_UNMET" },
    { "code": "CONTEXT_INSUFFICIENT", "trigger": { "wiremapContext": null }, "expect": "CONTEXT_INSUFFICIENT" },
    { "code": "COMPOSE_EMPTY_REJECTED", "trigger": { "fragments": [] }, "expect": "COMPOSE_EMPTY_REJECTED" },
    { "code": "SLICE_UNDERFLOW", "trigger": { "tokens": 10 }, "expect": "SLICE_UNDERFLOW" },
    { "code": "SLICE_TRUNCATED", "trigger": { "tokens": 50000 }, "expect": "SLICE_TRUNCATED" },
    { "code": "FALSE_COMPLIANCE_SUSPECTED", "trigger": { "emptyFile": true }, "expect": "FALSE_COMPLIANCE_SUSPECTED" },
    { "code": "STRIPE_VARIANT_REQUIRED", "trigger": { "stripeVariants": [] }, "expect": "STRIPE_VARIANT_REQUIRED" },
    { "code": "RULESET_DEPRECATED", "trigger": { "rulesetVersion": "2020.01.01" }, "expect": "RULESET_DEPRECATED" },
    { "code": "ABUSE_DETECTED", "trigger": { "abuseScore": 99 }, "expect": "ABUSE_DETECTED" },
    { "code": "SCOPE_DISCLAIMER", "trigger": { "market": "eu" }, "expect": "SCOPE_DISCLAIMER" }
  ]
}

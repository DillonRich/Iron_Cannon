{
  "$schema": "https://ironcannon.dev/schemas/rule-fragment/v1",
  "id": "layer2/pages/env-bridge",
  "layer": 2,
  "rulesetVersion": "2026.05.31",
  "flowId": "auth-lifecycle",
  "moduleId": "M61-pages-env-bridge",
  "adapterId": "cloudflare-pages",
  "section": "pages-env-bridge",
  "content": {
    "requirement": "Public NEXT_PUBLIC_API_URL for Pages frontend; Worker vars for server-side APP_URL"
  },
  "references": ["nextjs/docs-app-building-your-application-configuring-environment-variables", "cloudflare/workers-environment-variables"],
  "compliancePatterns": {
    "required": [
      {
        "id": "PAGES-ENV-001",
        "type": "required_string",
        "value": "NEXT_PUBLIC_API_URL",
        "fileGlob": "**/.env*",
        "tier": "pro"
      },
      {
        "id": "PAGES-ENV-002",
        "type": "required_string",
        "value": "APP_URL",
        "fileGlob": "**/wrangler*.toml",
        "tier": "pro"
      }
    ],
    "forbidden": []
  },
  "metadata": { "minTier": "pro", "category": "pages-deploy" }
}
